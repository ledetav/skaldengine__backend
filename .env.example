# === INFRASTRUCTURE (Shared) ===
# This file contains shared credentials for Docker Compose and local environment reference.
# Service-specific settings are located in ./services/<service_name>/.env.example

# Redis
REDIS_URL=redis://localhost:6379

# === DOCKER POSTGRES CREDENTIALS ===
# These match the settings in docker-compose.yml

# Auth DB
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_password
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_PORT=5432

# Core DB
CORE_POSTGRES_USER=core_user
CORE_POSTGRES_PASSWORD=core_password
CORE_POSTGRES_DB=core_db
CORE_POSTGRES_PORT=5433
