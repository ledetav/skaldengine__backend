# SKALDEngine Consolidated Configuration Example

# --- Common / Shared Settings ---
LOG_LEVEL=INFO
SECRET_KEY=secret_key_for_jwt
ALGORITHM=HS256
API_V1_STR="/api/v1"

AUTH_PASSWORD=auth_pass
CORE_PASSWORD=core_pass

# --- Auth Service settings ---
AUTH_PROJECT_NAME="SkaldEngine Auth Service"
AUTH_DATABASE_URL=postgresql+asyncpg://auth_user:${AUTH_PASSWORD}@localhost:5435/auth_db
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Core Service settings ---
CORE_PROJECT_NAME="SkaldEngine Core Service"
CORE_DATABASE_URL=postgresql+asyncpg://core_user:${CORE_PASSWORD}@localhost:5436/core_db
CORE_UPLOAD_DIR=./uploads

# AI / Polza.ai Settings (OpenAI Wrapper)
# POLZA_API_KEY is used as a global fallback if user has not provided their own key.
POLZA_API_KEY=key
POLZA_CHAT_MODEL=google/gemini-3-flash-preview
POLZA_EMBEDDING_MODEL=openai/text-embedding-3-small
POLZA_SUMMARY_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_TITLE_MODEL=google/gemini-2.0-flash-lite-preview-02-05
POLZA_TEMPERATURE=1.0
POLZA_MAX_TOKENS=8000
POLZA_TITLE_MAX_TOKENS=50

BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
