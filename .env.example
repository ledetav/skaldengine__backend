# === INFRASTRUCTURE (Shared) ===
REDIS_URL=redis://localhost:6379

# === AUTH SERVICE ===
AUTH_PROJECT_NAME="SkaldEngine Auth Service"
AUTH_API_V1_STR="/api/v1"
AUTH_SECRET_KEY=your_secret_key_here
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Database URL for Auth Service (PostgreSQL)
AUTH_DATABASE_URL=postgresql+asyncpg://auth_user:auth_password@localhost:5432/auth_db

# === CORE SERVICE ===
CORE_PROJECT_NAME="SkaldEngine Core Service"
CORE_API_V1_STR="/api/v1"
CORE_SECRET_KEY=your_secret_key_here
CORE_ALGORITHM=HS256
# Database URL for Core Service (PostgreSQL)
CORE_DATABASE_URL=postgresql+asyncpg://core_user:core_password@localhost:5433/core_db

# AI / Gemini Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_TOKENS=8000

# Storage
UPLOAD_DIR=./uploads

# === DATABASE (Docker Compose Internal) ===
# Auth DB
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=auth_password
AUTH_POSTGRES_DB=auth_db

# Core DB
CORE_POSTGRES_USER=core_user
CORE_POSTGRES_PASSWORD=core_password
CORE_POSTGRES_DB=core_db
