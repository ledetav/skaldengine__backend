# ─────────────────────────────────────────────────────────────────────────────
# SKALDEngine Backend — Environment Variables Example
# Скопируй этот файл в .env и заполни значения.
# ─────────────────────────────────────────────────────────────────────────────

# ── Общие / Shared ────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
SECRET_KEY=change_me_to_a_long_random_secret
ALGORITHM=HS256
API_V1_STR=/api/v1
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── БД пароли (используются в docker-compose) ─────────────────────────────────

AUTH_PASSWORD=auth_strong_password
CORE_PASSWORD=core_strong_password

# ── Auth Service ──────────────────────────────────────────────────────────────

AUTH_PROJECT_NAME=SkaldEngine Auth Service

# Docker: автоматически подставляется из docker-compose.
# Локально без Docker — укажи адрес вручную:

# ── Core Service ──────────────────────────────────────────────────────────────

CORE_PROJECT_NAME=SkaldEngine Core Service

# Docker: автоматически подставляется из docker-compose.
# Локально без Docker — укажи адрес вручную:
AUTH_DATABASE_URL=postgresql+asyncpg://auth_user:${AUTH_PASSWORD}@auth-db:5432/auth_db
CORE_DATABASE_URL=postgresql+asyncpg://core_user:${CORE_PASSWORD}@core-db:5432/core_db

CORE_UPLOAD_DIR=./uploads

# ── AI / Polza.ai ─────────────────────────────────────────────────────────────

# Глобальный API-ключ (фоллбэк, если у пользователя нет своего)
POLZA_API_KEY=your_polza_api_key_here

POLZA_CHAT_MODEL=google/gemini-3-flash-preview
POLZA_EMBEDDING_MODEL=openai/text-embedding-3-small
POLZA_SUMMARY_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_TITLE_MODEL=google/gemini-2.0-flash-lite-preview-02-05
POLZA_TEMPERATURE=1.0
POLZA_MAX_TOKENS=8000
POLZA_TITLE_MAX_TOKENS=50

# ── Gateway / CORS ────────────────────────────────────────────────────────────

# Порт, на котором gateway будет доступен снаружи (Docker)
GATEWAY_PORT=80

# URL сервисов для Docker (gateway → internal service names)
# Не меняй, если используешь docker-compose.
AUTH_BASE_URL=http://auth:8001
CORE_BASE_URL=http://core:8000

# Точные разрешённые origins (JSON-список)
BACKEND_CORS_ORIGINS=["https://skaldengine.com", "https://www.skaldengine.com"]

# Суффиксы для динамических Replit / dev доменов
BACKEND_CORS_ALLOWED_SUFFIXES=[".replit.dev", ".replit.app", "localhost", "127.0.0.1"]
