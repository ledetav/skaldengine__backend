PROJECT_NAME="SkaldEngine Core Service"
API_V1_STR="/api/v1"
SECRET_KEY="your_secret_key_here"
ALGORITHM=HS256

# Database URL (PostgreSQL)
# Note: Use localhost:5433 if running locally, or core-db:5432 if running in Docker
DATABASE_URL=postgresql+asyncpg://core_user:core_password@localhost:5433/core_db

# Redis Connection (Cache / Tasks)
REDIS_URL=redis://localhost:6379

# AI / Gemini Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_TOKENS=8000

# Storage
UPLOAD_DIR=./uploads
