PROJECT_NAME="SkaldEngine Core Service"
API_V1_STR="/api/v1"
SECRET_KEY="your_secret_key_here"
ALGORITHM=HS256

# Database URL (PostgreSQL)
# Note: Use localhost:5433 if running locally, or core-db:5432 if running in Docker
DATABASE_URL=postgresql+asyncpg://core_user:core_password@localhost:5433/core_db

# Redis Connection (Cache / Tasks)
REDIS_URL=redis://localhost:6379

# AI / Polza.ai Settings (OpenAI Wrapper)
POLZA_API_KEY=your_polza_api_key_here
POLZA_CHAT_MODEL=google/gemini-3-flash-preview
POLZA_EMBEDDING_MODEL=openai/text-embedding-3-small
POLZA_SUMMARY_MODEL=google/gemini-3.1-flash-lite-preview
POLZA_TEMPERATURE=1.0
POLZA_MAX_TOKENS=8000

# Storage
UPLOAD_DIR=./uploads
