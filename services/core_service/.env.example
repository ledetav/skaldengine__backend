PROJECT_NAME="SkaldEngine Core Service"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-change-in-production"

# PostgreSQL (с pgvector). Локально порт 5433 (core-db).
DATABASE_URL="postgresql+asyncpg://core_user:core_password@localhost:5433/core_db"

# Redis (ARQ broker + cache). Локально порт 6379.
REDIS_URL="redis://localhost:6379"

# Google Gemini API Key
GEMINI_API_KEY="your-google-gemini-api-key"

# Vertex AI (опционально, если используете Vertex вместо AI Studio)
VERTEX_PROJECT_ID=""
VERTEX_LOCATION="us-central1"

# Директория для загруженных файлов (аватарки, карточки)
UPLOAD_DIR="./uploads"