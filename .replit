modules = ["python-3.12", "nix", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ALGORITHM = "HS256"
API_V1_STR = "/api/v1"
AUTH_PROJECT_NAME = "SkaldEngine Auth Service"
CORE_PROJECT_NAME = "SkaldEngine Core Service"
ACCESS_TOKEN_EXPIRE_MINUTES = "60"
POLZA_CHAT_MODEL = "google/gemini-3-flash-preview"
POLZA_EMBEDDING_MODEL = "openai/text-embedding-3-small"
POLZA_SUMMARY_MODEL = "google/gemini-3.1-flash-lite-preview"
POLZA_TITLE_MODEL = "google/gemini-2.0-flash-lite-preview-02-05"
POLZA_TEMPERATURE = "1.0"
POLZA_MAX_TOKENS = "8000"
POLZA_TITLE_MAX_TOKENS = "50"
SECRET_KEY = "c46e63b1ac738dd036fc4d6ffe88836e0feecba4c456fa10a9c16ff8c77e3c9d"
AUTH_DATABASE_URL = "postgresql+asyncpg://neondb_owner:npg_8lcFakePHEu0@ep-blue-surf-anep7arp.c-6.us-east-1.aws.neon.tech/neondb?ssl=require"
CORE_DATABASE_URL = "postgresql+asyncpg://neondb_owner:npg_8lcFakePHEu0@ep-blue-surf-anep7arp.c-6.us-east-1.aws.neon.tech/neondb?ssl=require"
BACKEND_CORS_ORIGINS = '["https://27ce52ae-181e-42ce-b7e3-15a281b159e2-00-3dwzya1att87j.picard.replit.dev", "http://localhost:5173"]'
CORS_ALLOW_ORIGIN_REGEX = 'https://.*\.replit\.dev'

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start_gateway.sh"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000
exposeLocalhost = true

[[ports]]
localPort = 8001
externalPort = 3000
exposeLocalhost = true

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "start_gateway.sh"]
